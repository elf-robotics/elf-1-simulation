<mujoco model="elf1_mini_biped">

  <compiler angle="degree"/>
  <option gravity="0 0 -9.81" timestep="0.002"/>

  <visual>
    <map znear="0.01"/>
    <global azimuth="140" elevation="-20"/>
  </visual>

  <default>
    <joint damping="1.0" armature="0.01"/>
    <geom friction="0.8 0.1 0.1" density="500" rgba="0.2 0.6 1 1"/>
    <motor ctrllimited="true" ctrlrange="-1 1"/>
  </default>

  <worldbody>

    <geom name="floor"
          type="plane"
          size="2 2 0.1"
          rgba="0.9 0.9 0.9 1"/>

    <light name="sun"
           pos="0 0 2"
           dir="0 0 -1"
           diffuse="1 1 1"
           specular="0.2 0.2 0.2"/>

    <camera name="nice_view"
            pos="0.6 -0.8 0.45"
            xyaxes="0.8 0.6 0  -0.2 0.3 0.93"/>

    <body name="torso" pos="0 0 0.24">
      <freejoint/>

      <geom name="torso_geom"
            type="box"
            size="0.045 0.025 0.055"
            mass="0.45"
            rgba="0.15 0.35 0.65 1"/>

      <!-- Kopf -->
      <body name="head" pos="0 0 0.085">
        <geom type="sphere"
              size="0.03"
              mass="0.08"
              rgba="0.95 0.82 0.65 1"/>
      </body>

      <!-- LINKES BEIN -->

      <body name="left_thigh" pos="0.03 0 -0.055">

        <joint name="left_hip"
               type="hinge"
               axis="0 1 0"
               range="-35 35"/>

        <geom type="capsule"
              fromto="0 0 0 0 0 -0.07"
              size="0.014"
              mass="0.08"/>

        <body name="left_shin" pos="0 0 -0.07">

          <joint name="left_knee"
                 type="hinge"
                 axis="0 1 0"
                 range="0 90"/>

          <geom type="capsule"
                fromto="0 0 0 0 0 -0.07"
                size="0.013"
                mass="0.07"/>

          <body name="left_foot" pos="0 0 -0.07" euler="0 0 -90">

            <geom type="box"
                  size="0.042 0.022 0.008"
                  pos="0 0 0"
                  mass="0.05"
                  rgba="0.12 0.30 0.58 1"/>

          </body>
        </body>
      </body>

      <!-- RECHTES BEIN -->

      <body name="right_thigh" pos="-0.03 0 -0.055">

        <joint name="right_hip"
               type="hinge"
               axis="0 1 0"
               range="-35 35"/>

        <geom type="capsule"
              fromto="0 0 0 0 0 -0.07"
              size="0.014"
              mass="0.08"/>

        <body name="right_shin" pos="0 0 -0.07">

          <joint name="right_knee"
                 type="hinge"
                 axis="0 1 0"
                 range="0 90"/>

          <geom type="capsule"
                fromto="0 0 0 0 0 -0.07"
                size="0.013"
                mass="0.07"/>

          <body name="right_foot" pos="0 0 -0.07" euler="0 0 90">

            <geom type="box"
                  size="0.042 0.022 0.008"
                  pos="0 0 0"
                  mass="0.05"
                  rgba="0.12 0.30 0.58 1"/>

          </body>
        </body>
      </body>

      <!-- LINKER ARM (2 DOF Schulter) -->

      <body name="left_shoulder_pitch_body" pos="0.055 0 0.02">

        <inertial pos="0 0 0"
                  mass="0.005"
                  diaginertia="1e-5 1e-5 1e-5"/>

        <joint name="left_shoulder_pitch"
               type="hinge"
               axis="1 0 0"
               range="-80 80"/>

        <body name="left_shoulder_roll_body" pos="0 0 0">

          <joint name="left_shoulder_roll"
                 type="hinge"
                 axis="0 1 0"
                 range="-80 80"/>

          <geom type="capsule"
                fromto="0 0 0 0 0 -0.08"
                size="0.011"
                mass="0.04"
                rgba="0.18 0.45 0.80 1"/>

        </body>
      </body>

      <!-- RECHTER ARM (2 DOF Schulter) -->

      <body name="right_shoulder_pitch_body" pos="-0.055 0 0.02">

        <inertial pos="0 0 0"
                  mass="0.005"
                  diaginertia="1e-5 1e-5 1e-5"/>

        <joint name="right_shoulder_pitch"
               type="hinge"
               axis="1 0 0"
               range="-80 80"/>

        <body name="right_shoulder_roll_body" pos="0 0 0">

          <joint name="right_shoulder_roll"
                 type="hinge"
                 axis="0 1 0"
                 range="-80 80"/>

          <geom type="capsule"
                fromto="0 0 0 0 0 -0.08"
                size="0.011"
                mass="0.04"
                rgba="0.18 0.45 0.80 1"/>

        </body>
      </body>

    </body>
  </worldbody>

  <actuator>

    <motor name="m_left_hip" joint="left_hip" gear="20"/>
    <motor name="m_left_knee" joint="left_knee" gear="20"/>

    <motor name="m_right_hip" joint="right_hip" gear="20"/>
    <motor name="m_right_knee" joint="right_knee" gear="20"/>

    <motor name="m_left_shoulder_pitch" joint="left_shoulder_pitch" gear="10"/>
    <motor name="m_left_shoulder_roll" joint="left_shoulder_roll" gear="10"/>

    <motor name="m_right_shoulder_pitch" joint="right_shoulder_pitch" gear="10"/>
    <motor name="m_right_shoulder_roll" joint="right_shoulder_roll" gear="10"/>

  </actuator>

  <keyframe>
    <key name="home"
         qpos="0 0 0.24  1 0 0 0   0 0.2  0 0.2   0 0   0 0"/>
  </keyframe>

</mujoco>
